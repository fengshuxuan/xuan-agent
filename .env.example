APP_ENV=development
DATABASE_URL=sqlite:///./xuan_agent.db
# For docker compose / PostgreSQL:
# DATABASE_URL=postgresql+psycopg://xuan_agent:xuan_agent@localhost:5432/xuan_agent
SECRET_KEY=replace-this-with-a-long-random-secret
ACCESS_TOKEN_EXPIRE_MINUTES=1440
WORKSPACE_ROOT=./workspace

LLM_PROVIDER=doubao
LLM_TOOL_CALLING_ENABLED=true
LLM_MAX_TOOL_ROUNDS=3
DOUBAO_API_KEY=
DOUBAO_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
DOUBAO_MODEL=doubao-seed-2.1-pro

SANDBOX_IMAGE=xuan-agent-python-sandbox:latest
SANDBOX_TIMEOUT_SECONDS=10
SANDBOX_MEMORY=512m
SANDBOX_CPUS=1

FREE_MONTHLY_MESSAGES=100
FREE_MONTHLY_CODE_EXECUTIONS=20
MAX_UPLOAD_FILE_BYTES=10485760

REDIS_URL=redis://localhost:6379/0
WORKER_ENABLED=false
